{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../dist/main",
    "rootDir": ".",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],
    "noEmitOnError": true
  },
  "include": ["*.ts"]
}
